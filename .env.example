# Copy this file to .env and fill in your own values.

# Your Anthropic API key (https://console.anthropic.com -> API Keys).
ANTHROPIC_API_KEY=your_anthropic_api_key

# The numeric GA4 property ID you want to query
# (GA4 -> Admin -> Property Settings -> Property ID).
GA4_PROPERTY_ID=your_property_id

# Optional: override the Claude model. Defaults to claude-sonnet-4-6 in agent.py.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# NOTE on Google authentication:
# This project authenticates to GA4 with your own Google user account via the
# gcloud CLI (Application Default Credentials), NOT a service-account key file.
# There is therefore no GOOGLE_APPLICATION_CREDENTIALS here. Run this once:
#
#   gcloud auth application-default login \
#     --scopes=https://www.googleapis.com/auth/analytics.readonly,https://www.googleapis.com/auth/cloud-platform
#
# See the README "Setup" section for the full walkthrough.
